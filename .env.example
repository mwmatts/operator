# Operator Agent — environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Telegram bot token for @CortexOperatorBot
OPERATOR_TELEGRAM_BOT_TOKEN=

# CortexShell authorization gate
CORTEXSHELL_URL=http://localhost:8100

# KIOS SQLite DB path (host path — mounted as volume in Docker)
KIOS_DB_PATH=/data/kios.db
